# FailoverOS simulated environment template
# Copy this file to .env.local to customize local parameters.

# Simulator core configs
VITE_SIMULATOR_SPEED=1
VITE_DEFAULT_REGION=us-east-1

# Model routing settings
VITE_PRIMARY_MODEL=gpt-4o
VITE_SECONDARY_MODEL=claude-3-5-sonnet
VITE_FALLBACK_MODEL=llama-3-8b-instruct
